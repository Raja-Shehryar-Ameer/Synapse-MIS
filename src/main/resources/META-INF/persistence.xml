<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="synapse-file-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.synapse.model.Patient</class>
        <class>com.synapse.model.EmergencyProfile</class>
        <class>com.synapse.model.VitalLog</class>
        <class>com.synapse.model.SymptomLog</class>
        <class>com.synapse.model.WeightLog</class>
        <class>com.synapse.model.DietLog</class>
        <class>com.synapse.model.FoodItem</class>
        <class>com.synapse.model.HydrationLog</class>
        <class>com.synapse.model.JournalEntry</class>
        <class>com.synapse.model.Medicine</class>
        <class>com.synapse.model.MedicationSchedule</class>
        <class>com.synapse.model.CalendarEvent</class>
        <class>com.synapse.model.SystemAlert</class>
        <class>com.synapse.model.DrugInteraction</class>
        <class>com.synapse.model.MedicalRecord</class>
        <class>com.synapse.model.HealthcareFacility</class>
        <class>com.synapse.model.HealthReport</class>
        <class>com.synapse.model.DataBackup</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:file:./synapse-data/synapse-db;AUTO_SERVER=TRUE"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hikari.minimumIdle" value="2"/>
            <property name="hibernate.hikari.maximumPoolSize" value="5"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="synapse-sql-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.synapse.model.Patient</class>
        <class>com.synapse.model.EmergencyProfile</class>
        <class>com.synapse.model.VitalLog</class>
        <class>com.synapse.model.SymptomLog</class>
        <class>com.synapse.model.WeightLog</class>
        <class>com.synapse.model.DietLog</class>
        <class>com.synapse.model.FoodItem</class>
        <class>com.synapse.model.HydrationLog</class>
        <class>com.synapse.model.JournalEntry</class>
        <class>com.synapse.model.Medicine</class>
        <class>com.synapse.model.MedicationSchedule</class>
        <class>com.synapse.model.CalendarEvent</class>
        <class>com.synapse.model.SystemAlert</class>
        <class>com.synapse.model.DrugInteraction</class>
        <class>com.synapse.model.MedicalRecord</class>
        <class>com.synapse.model.HealthcareFacility</class>
        <class>com.synapse.model.HealthReport</class>
        <class>com.synapse.model.DataBackup</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:sqlserver://HAIDER-RAMZAN\SQLEXPRESS;databaseName=PatientDB;encrypt=true;trustServerCertificate=true;integratedSecurity=true"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.SQLServerDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hikari.minimumIdle" value="2"/>
            <property name="hibernate.hikari.maximumPoolSize" value="5"/>
            <property name="hibernate.hikari.connectionTimeout" value="3000"/>
        </properties>
    </persistence-unit>
</persistence>
